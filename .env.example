# Polymarket Trading System - Environment Variables

# Polymarket API
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_secret
POLYMARKET_WS_ENDPOINT=wss://ws.polymarket.com

# Wallet (Required for real trading)
PRIVATE_KEY=0x_your_wallet_private_key
WALLET_ADDRESS=0x_your_wallet_address
RPC_URL=https://polygon-rpc.com

# Exchange APIs (Crypto Secondary)
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET=your_binance_secret
COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET=your_coinbase_secret
KRAKEN_API_KEY=your_kraken_key
KRAKEN_SECRET=your_kraken_secret

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Risk Parameters (override database defaults)
MAX_POSITION_USD=1
KELLY_MULTIPLIER=0.25
MAX_DAILY_DRAWDOWN_PCT=5
MAX_PORTFOLIO_HEAT_PCT=20
MIN_EDGE_PCT=2
MAX_SLIPPAGE_PCT=1
